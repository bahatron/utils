{
    "name": "@bahatron/utils",
    "version": "4.2.3",
    "description": "The only utility library you'll ever need",
    "main": "lib/index.js",
    "types": "lib/index.d.ts",
    "scripts": {
        "test": "vitest run",
        "watch": "tsc -b -w tsconfig.build.json",
        "build": "tsc -p tsconfig.build.json && dts-bundle-generator --export-referenced-types=false --external-inlines @sinclair/typebox jsonschema -o lib/index.d.ts src/index.ts",
        "build:clean": "rm -rf lib && npm run build",
        "preversion": "npm run build:clean && npm run test",
        "prepare": "husky"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/bahatron/utils.git"
    },
    "author": "simonpiscitelli@gmail.com",
    "license": "Apache-2.0",
    "bugs": {
        "url": "https://github.com/bahatron/utils/issues"
    },
    "homepage": "https://github.com/bahatron/utils#readme",
    "devDependencies": {
        "@types/node": "^20.19.30",
        "dts-bundle-generator": "^9.5.1",
        "husky": "^9.1.7",
        "vitest": "^3.1.1",
        "typescript": "^5.9.3"
    },
    "dependencies": {
        "@sinclair/typebox": "^0.34.48",
        "fast-safe-stringify": "^2.1.1",
        "jsonschema": "^1.5.0"
    }
}
